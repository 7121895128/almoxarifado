        repository.findById(id)
                .orElseThrow(() -> new ResourceNotFoundException(
                        "Produto não encontrado com o ID: " + id));

        repository.deleteById(id);
        return ResponseEntity.noContent().build();
    }
}

//Movimentacao Estoque Contreoller

package com.br.almoxarifado.controller;

import java.net.URI;
import java.util.List;
import org.springframework.data.domain.Sort;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;
import org.springframework.web.servlet.support.ServletUriComponentsBuilder;
import com.br.almoxarifado.exception.ResourceNotFoundException;
import com.br.almoxarifado.model.MovimentacaoEstoque;
import com.br.almoxarifado.repository.MovimentacaoEstoqueRepository;

@RestController
@RequestMapping("/cmovimentacao")
@CrossOrigin(origins = "*")
public class MovimentacaoEstoqueController {

    private final MovimentacaoEstoqueRepository repository;

    // Injeção do repositório via construtor
    public MovimentacaoEstoqueController(MovimentacaoEstoqueRepository repository) {
        this.repository = repository;
    }

    // LISTAR — GET
    @GetMapping("/movimentacao")
    public List<MovimentacaoEstoque> listar() {
        return repository.findAll(Sort.by(Sort.Direction.DESC, "codigo"));
    }

    // CONSULTAR — GET
    @GetMapping("/movimentacao/{id}")
    public ResponseEntity<MovimentacaoEstoque> consultar(@PathVariable Long id) {
        MovimentacaoEstoque movimentacao = repository.findById(id)
                .orElseThrow(() -> new ResourceNotFoundException(
                        "Movimentação não encontrada com o ID: " + id));
        return ResponseEntity.ok(movimentacao);
    }

    // INSERIR — POST
    @PostMapping("/movimentacao")
    public ResponseEntity<MovimentacaoEstoque> inserir(
            @RequestBody MovimentacaoEstoque movimentacao) {

        MovimentacaoEstoque novaMovimentacao = repository.save(movimentacao);

        URI uri = ServletUriComponentsBuilder.fromCurrentRequest()
                .path("/{id}")
                .buildAndExpand(novaMovimentacao.getCodigo())
                .toUri();
        return ResponseEntity.created(uri).body(novaMovimentacao);
    }

    // ALTERAR — PUT
    @PutMapping("/movimentacao/{id}")
    public ResponseEntity<MovimentacaoEstoque> alterar(
            @PathVariable Long id,
            @RequestBody MovimentacaoEstoque dadosNovos) {

        MovimentacaoEstoque movExistente = repository.findById(id)
                .orElseThrow(() -> new ResourceNotFoundException(
                        "Movimentação não encontrada com o ID: " + id));

        // Atualiza todos os campos com os dados novos recebidos
        movExistente.setTipo(dadosNovos.getTipo());
        movExistente.setQuantidade(dadosNovos.getQuantidade());
        movExistente.setDataHora(dadosNovos.getDataHora());
        movExistente.setResponsavel(dadosNovos.getResponsavel());
        movExistente.setObservacao(dadosNovos.getObservacao());
        movExistente.setConferido(dadosNovos.getConferido());
        movExistente.setProduto(dadosNovos.getProduto());

        MovimentacaoEstoque movAtualizada = repository.save(movExistente);
        return ResponseEntity.ok(movAtualizada);
    }

    // EXCLUIR — DELETE
    @DeleteMapping("/movimentacao/{id}")
    public ResponseEntity<Void> excluir(@PathVariable Long id) {
        repository.findById(id)
                .orElseThrow(() -> new ResourceNotFoundException(
                        "Movimentação não encontrada com o ID: " + id));

        repository.deleteById(id);
        return ResponseEntity.noContent().build();
    }
}
