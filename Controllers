        produtoExistente.setCodigoBarras(dadosNovos.getCodigoBarras());
        produtoExistente.setQuantidadeEstoque(dadosNovos.getQuantidadeEstoque());
        produtoExistente.setPrecoUnitario(dadosNovos.getPrecoUnitario());
        produtoExistente.setDataValidade(dadosNovos.getDataValidade());
        produtoExistente.setAtivo(dadosNovos.getAtivo());
        produtoExistente.setUnidadeMedida(dadosNovos.getUnidadeMedida());
        produtoExistente.setCategoria(dadosNovos.getCategoria());

        Produto produtoAtualizado = repository.save(produtoExistente);
        return ResponseEntity.ok(produtoAtualizado);
    }

    // EXCLUIR — DELETE
    @DeleteMapping("/produto/{id}")
