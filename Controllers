//Categoria Controller

package com.br.almoxarifado.controller;

import java.net.URI;
import java.util.List;
import org.springframework.data.domain.Sort;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;
import org.springframework.web.servlet.support.ServletUriComponentsBuilder;
import com.br.almoxarifado.exception.ResourceNotFoundException;
import com.br.almoxarifado.model.Categoria;
import com.br.almoxarifado.repository.CategoriaRepository;

@RestController
@RequestMapping("/ccategoria")
@CrossOrigin(origins = "*")
public class CategoriaController {

    private final CategoriaRepository repository;

    public CategoriaController(CategoriaRepository repository) {
        this.repository = repository;
    }

    // LISTAR — GET
    @GetMapping("/categoria")
    public List<Categoria> listar() {
        return repository.findAll(Sort.by(Sort.Direction.DESC, "codigo"));
    }

    // CONSULTAR — GET
    @GetMapping("/categoria/{id}")
    public ResponseEntity<Categoria> consultar(@PathVariable Long id) {
        Categoria categoria = repository.findById(id)
                .orElseThrow(() -> new ResourceNotFoundException(
                        "Categoria não encontrada com o ID: " + id));
        return ResponseEntity.ok(categoria);
    }

    // INSERIR — POST
    @PostMapping("/categoria")
    public ResponseEntity<Categoria> inserir(@RequestBody Categoria categoria) {
        Categoria novaCategoria = repository.save(categoria);

        URI uri = ServletUriComponentsBuilder.fromCurrentRequest()
                .path("/{id}")
                .buildAndExpand(novaCategoria.getCodigo())
                .toUri();
        return ResponseEntity.created(uri).body(novaCategoria);
    }

    // Atualiza todos os campos da categoria com os dados recebidos no JSON
    @PutMapping("/categoria/{id}")
    public ResponseEntity<Categoria> alterar(@PathVariable Long id,
                                              @RequestBody Categoria dadosNovos) {
        Categoria categoriaExistente = repository.findById(id)
                .orElseThrow(() -> new ResourceNotFoundException(
                        "Categoria não encontrada com o ID: " + id));

        // Sobrescreve cada campo com o novo valor recebido
        categoriaExistente.setNome(dadosNovos.getNome());
        categoriaExistente.setDescricao(dadosNovos.getDescricao());
        categoriaExistente.setAtivo(dadosNovos.getAtivo());
        categoriaExistente.setCodigoInterno(dadosNovos.getCodigoInterno());
        categoriaExistente.setLimiteEstoque(dadosNovos.getLimiteEstoque());

        Categoria categoriaAtualizada = repository.save(categoriaExistente);
        return ResponseEntity.ok(categoriaAtualizada);
    }

    // EXCLUIR — DELETE
    @DeleteMapping("/categoria/{id}")
    public ResponseEntity<Void> excluir(@PathVariable Long id) {
        repository.findById(id)
                .orElseThrow(() -> new ResourceNotFoundException(
                        "Categoria não encontrada com o ID: " + id));

        repository.deleteById(id);
        return ResponseEntity.noContent().build();
    }
}

