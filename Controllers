    public ResponseEntity<Produto> inserir(@RequestBody Produto produto) {
        Produto novoProduto = repository.save(produto);

        URI uri = ServletUriComponentsBuilder.fromCurrentRequest()
                .path("/{id}")
                .buildAndExpand(novoProduto.getCodigo())
